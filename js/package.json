{
  "name": "kimg",
  "version": "0.5.0",
  "description": "Rust+WASM pixel engine for layer-based image compositing — blend modes, masks, filters, transforms, sprite tools, multi-format I/O",
  "type": "module",
  "main": "kimg_wasm.js",
  "module": "kimg_wasm.js",
  "types": "kimg_wasm.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./kimg_wasm.d.ts",
      "import": "./kimg_wasm.js"
    },
    "./base64": {
      "types": "./base64.d.ts",
      "import": "./base64.js"
    },
    "./color-utils": {
      "types": "./color-utils.d.ts",
      "import": "./color-utils.js"
    }
  },
  "files": [
    "kimg_wasm.js",
    "kimg_wasm.d.ts",
    "kimg_wasm_bg.js",
    "kimg_wasm_bg.d.ts",
    "kimg_wasm_bg.wasm",
    "kimg_wasm_bg.wasm.d.ts",
    "kimg_wasm_simd.js",
    "kimg_wasm_simd.d.ts",
    "kimg_wasm_simd_bg.wasm",
    "kimg_wasm_simd_bg.wasm.d.ts",
    "base64.js",
    "base64.d.ts",
    "color-utils.js",
    "color-utils.d.ts"
  ],
  "keywords": [
    "image",
    "compositor",
    "wasm",
    "webassembly",
    "pixel",
    "layer",
    "blend",
    "filter",
    "sprite",
    "png",
    "jpeg",
    "webp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamkaf/kimg"
  }
}
